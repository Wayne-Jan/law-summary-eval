rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /evals/{evaluator}/records/{recordId} {
      allow read, write: if isSignedInAllowedUser() && evaluator == request.auth.uid && isValidRecord();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedInAllowedUser() {
      return request.auth != null
        && request.auth.token.email in [
          'wmq@law-eval.local',
          'lhz@law-eval.local',
          'dhz@law-eval.local',
          'scr@law-eval.local',
          'admin@law-eval.local'
        ];
    }

    function isValidRecord() {
      return request.resource != null
        && request.resource.data.keys().hasOnly(['key', 'data', 'updated'])
        && request.resource.data.key is string
        && request.resource.data.key.size() > 0
        && request.resource.data.key.size() <= 1500
        && request.resource.data.key.matches('^(eval_v2_|eval_v2_condorder_).+')
        && request.resource.data.data != null;
    }
  }
}
